# API Configuration
VITE_API_BASE_URL=http://localhost:3000/api

# Basic Authentication (optional)
# Format: username:password (will be base64 encoded automatically)
VITE_API_BASIC_AUTH_USERNAME=
VITE_API_BASIC_AUTH_PASSWORD=

# Or use a single combined auth string (base64 encoded username:password)
# VITE_API_BASIC_AUTH=
