# Execution system (meetings, auth, presentations, etc.)
VITE_APP_BASE_URL_MINISTER=https://execution-system.momrahai.com

# Business cards / Adam meetings (e.g. توثيق الاجتماع – محضر، التوجيهات)
VITE_BUSINESS_CARDS_BASE_URL=https://momah-business-cards.momrahai.com/api/v1

# Unified platform (UC-09, UC-13) – remote module host
VITE_UEP_REMOTE_URL=https://admin-unified-patform-dev-2.momrahai.com/

# Text contradiction detector (تحليل التناقضات)
VITE_TEXT_CONTRADICTION_DETECTOR_URL=https://text-contradiction-detector.momrahai.com

# Meeting attendee suggestions (إضافة مدعوين آليًا)
VITE_INVITEE_SUGGESTIONS_URL=https://invitee.builtop.com

# Optional: model logos (defaults to https://models.dev)
# VITE_MODELS_LOGO_BASE_URL=https://models.dev

# Sentry (optional – errors show in dashboard when set)
VITE_SENTRY_DSN=

# SSO (OIDC) – when enabled, login uses IdP redirect instead of email/password
# Set to "true" to enable SSO; omit or set to anything else for basic auth only
# VITE_SSO_ENABLED=true
# VITE_SSO_AUTHORITY_URL=https://ssoappdev.momra.gov.sa
# VITE_SSO_CLIENT_ID=Outbalady.LegislationLibrary
#
# Interactive login callback URI (must be registered on the OIDC client)
# VITE_REDIRECT_URI=https://your-app.example.com/callback
#
# Silent renew iframe callback (defaults to {origin}/silent-renew). Register this URL on the
# same OIDC client as a second allowed redirect URI, or set explicitly:
# VITE_SILENT_REDIRECT_URI=https://your-app.example.com/silent-renew

# PostHog Analytics (optional)
VITE_PUBLIC_POSTHOG_KEY=
VITE_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

